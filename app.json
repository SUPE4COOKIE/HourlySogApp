{
	"expo": {
		"name": "HourlySogApp",
		"slug": "HourlySogApp",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "hourlysogapp",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#E6F4FE",
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			"edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false,
			"package": "com.anonymous.HourlySogApp"
		},
		"web": {
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#ffffff",
					"dark": {
						"backgroundColor": "#000000"
					}
				}
			],
			[
				"react-native-android-widget",
				{
					"widgets": [
						{
							"name": "SoggyCat",
							"label": "Hourly Soggy Cat",
							"minWidth": "110dp",
							"minHeight": "180dp",
							"targetCellWidth": 2,
							"targetCellHeight": 3,
							"resizeMode": "horizontal|vertical",
							"description": "This is the soggy cat widget. It shows a random soggy cat every hour.",
							"previewImage": "./assets/widget-preview/soggy.png",
							"updatePeriodMillis": 1800000
						}
					]
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		}
	}
}